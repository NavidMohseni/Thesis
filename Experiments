# ==============================================================================
# EXPERIMENT: The "No QR" Algorithm (Removing the Orthogonal Constraint)
# ==============================================================================

supervised_pca_cox_no_qr <- function(Z, time, status, K, theta = 0.5,
                               gamma = 0.001, max_iter = 100, tol = 1e-4) {
  
  n <- nrow(Z)
  p <- ncol(Z)
  Z_scaled <- scale(Z, center = TRUE, scale = TRUE)
  
  svd_Z <- svd(Z_scaled)
  U <- svd_Z$v[, 1:K, drop = FALSE]
  
  Z_recon <- Z_scaled %*% U %*% t(U)
  sigma2 <- mean((Z_scaled - Z_recon)^2) 
  
  Z_proj <- Z_scaled %*% U 
  df <- data.frame(time = time, status = status, Z_proj)
  cox_init <- suppressWarnings(coxph(Surv(time, status) ~ ., data = df))
  alpha <- matrix(coef(cox_init), ncol = 1) 
  
  cat("Starting unconstrained gradient ascent...\n")
  
  for (iter in 1:max_iter) {
    U_old <- U
    alpha_old <- alpha
    
    # Block A: Update Alpha
    Z_proj <- Z_scaled %*% U 
    df <- data.frame(time = time, status = status, Z_proj)
    
    # We use tryCatch because the Cox model might instantly crash if U explodes
    cox_fit <- tryCatch({
      suppressWarnings(coxph(Surv(time, status) ~ ., data = df))
    }, error = function(e) {
      return(NULL)
    })
    
    if (is.null(cox_fit)) {
      cat(sprintf("=> CRITICAL FAILURE: Cox model crashed at iteration %d due to infinite variance.\n", iter))
      break
    }
    
    alpha <- matrix(coef(cox_fit), ncol = 1) 
    d <- matrix(residuals(cox_fit, type = "martingale"), ncol = 1)
    
    # Block B: Update U (Gradient Ascent)
    G_data <- (1 / sigma2) * crossprod(Z_scaled) %*% U
    G_cox <- crossprod(Z_scaled, d) %*% t(alpha)
    G_total <- (theta * G_data) + ((1 - theta) * G_cox)
    
    # -> TAKE THE GRADIENT STEP
    U_temp <- U + gamma * G_total
    
    # -> THE CRUCIAL DELETION: WE REMOVED THE QR DECOMPOSITION HERE
    U <- U_temp 
    
    # --- SAFETY CATCH FOR EXPLOSIONS ---
    if (any(is.na(U)) || any(is.infinite(U))) {
      cat(sprintf("=> CRITICAL FAILURE: Matrix U exploded to NaN/Inf at iteration %d.\n", iter))
      break
    }

    # Block C: Check Convergence
    diff_alpha <- max(abs(alpha - alpha_old), na.rm = TRUE)
    diff_U <- max(abs(U - U_old), na.rm = TRUE)
    
    if (iter %% 10 == 0 || iter == 1) {
      cat(sprintf("Iter %3d: d_alpha = %.5f | d_U = %.5f\n", iter, diff_alpha, diff_U))
    }
    
    if (diff_alpha < tol && diff_U < tol) {
      cat(sprintf("=> Converged successfully at iteration %d\n", iter))
      break
    }
  }
  
  return(list(U = U, alpha = alpha, iterations = iter))
}

