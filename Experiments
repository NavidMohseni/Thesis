# ==============================================================================
# COMPARISON: Standard Cox (No Reduction) vs. Supervised PCA Cox (SVD)
# ==============================================================================

library(survival)
library(tidyverse)
library(patchwork)

# ------------------------------------------------------------------------------
# 1. SIMULATION SETUP (Train / Test Split)
# ------------------------------------------------------------------------------
set.seed(123)

n_train <- 150  
n_test <- 300   
p_sim <- 50     
K_sim <- 3 
noise_sd <- 0.8

# True parameters
U_true <- qr.Q(qr(matrix(rnorm(p_sim * K_sim), nrow = p_sim, ncol = K_sim)))
alpha_true <- matrix(c(-1.5, 0, 2.0), ncol = 1) 

# Generate Train Data
C_train <- matrix(rnorm(n_train * K_sim), nrow = n_train, ncol = K_sim)
Z_train_raw <- C_train %*% t(U_true) + matrix(rnorm(n_train * p_sim, sd = noise_sd), n_train, p_sim)
Z_train <- scale(Z_train_raw, center = TRUE, scale = TRUE)

eta_train_true <- Z_train %*% U_true %*% alpha_true
time_train <- rexp(n_train, rate = exp(eta_train_true))
censor_train <- rexp(n_train, rate = 0.5)
status_train <- ifelse(time_train <= censor_train, 1, 0)
time_train <- pmin(time_train, censor_train)

# Generate Test Data
C_test <- matrix(rnorm(n_test * K_sim), nrow = n_test, ncol = K_sim)
Z_test_raw <- C_test %*% t(U_true) + matrix(rnorm(n_test * p_sim, sd = noise_sd), n_test, p_sim)
Z_test <- scale(Z_test_raw, 
                center = attr(Z_train, "scaled:center"), 
                scale = attr(Z_train, "scaled:scale"))

eta_test_true <- Z_test %*% U_true %*% alpha_true
time_test <- rexp(n_test, rate = exp(eta_test_true))
censor_test <- rexp(n_test, rate = 0.5)
status_test <- ifelse(time_test <= censor_test, 1, 0)
time_test <- pmin(time_test, censor_test)

# ------------------------------------------------------------------------------
# 2. FIT THE THREE MODELS
# ------------------------------------------------------------------------------
cat("\n=== FITTING MODELS ===\n")

# Model 1: Standard Cox (No Dimension Reduction)
cat("1. Standard Cox (All", p_sim, "variables, no reduction)...\n")
df_train_std <- data.frame(time = time_train, status = status_train, Z_train)
fit_standard <- suppressWarnings(coxph(Surv(time, status) ~ ., data = df_train_std))

# Model 2: Proposed Supervised PCA Cox with SVD
cat("2. Supervised PCA Cox with SVD (K=3)...\n")
fit_proposed <- supervised_pca_cox_svd(
  Z = Z_train, 
  time = time_train, 
  status = status_train, 
  K = K_sim, 
  theta = 0.6, 
  gamma = 0.001
)

# ------------------------------------------------------------------------------
# 3. PREDICTIVE PERFORMANCE (C-INDEX)
# ------------------------------------------------------------------------------
cat("\n=== PREDICTIVE PERFORMANCE ===\n")

# Standard Cox predictions
df_test_std <- data.frame(Z_test)
colnames(df_test_std) <- colnames(df_train_std)[-c(1,2)]
eta_std_est <- predict(fit_standard, newdata = df_test_std)
c_std <- concordance(Surv(time_test, status_test) ~ eta_std_est)$concordance
c_std <- ifelse(c_std < 0.5, 1 - c_std, c_std)

# Proposed model predictions
eta_prop_est <- Z_test %*% fit_proposed$U %*% fit_proposed$alpha
c_prop <- concordance(Surv(time_test, status_test) ~ eta_prop_est)$concordance
c_prop <- ifelse(c_prop < 0.5, 1 - c_prop, c_prop)

# True risk C-index
c_true <- concordance(Surv(time_test, status_test) ~ eta_test_true)$concordance
c_true <- ifelse(c_true < 0.5, 1 - c_true, c_true)

cat(sprintf("True Risk C-Index:      %.4f\n", c_true))
cat(sprintf("Standard Cox C-Index:   %.4f\n", c_std))
cat(sprintf("Proposed Model C-Index: %.4f\n", c_prop))

# ------------------------------------------------------------------------------
# 4. SURVIVAL CURVE COMPARISON FOR REPRESENTATIVE PATIENTS
# ------------------------------------------------------------------------------
cat("\n=== GENERATING SURVIVAL CURVES ===\n")

# Select 3 representative patients: low, medium, high risk
quantiles <- quantile(eta_test_true, probs = c(0.25, 0.5, 0.75))
patient_indices <- sapply(quantiles, function(q) which.min(abs(eta_test_true - q)))

t_seq <- seq(0, max(time_test), length.out = 200)

# Function to create survival data for one patient
create_survival_data <- function(patient_idx, risk_group) {
  
  # 1. TRUE SURVIVAL CURVE (smooth exponential)
  surv_true <- exp(-exp(eta_test_true[patient_idx]) * t_seq)
  df_true <- tibble(
    Time = t_seq, 
    Survival = surv_true, 
    Model = "True",
    Patient = risk_group
  )
  
  # 2. STANDARD COX CURVE
  patient_std_data <- df_test_std[patient_idx, , drop = FALSE]
  surv_std_obj <- survfit(fit_standard, newdata = patient_std_data)
  df_std <- tibble(
    Time = surv_std_obj$time, 
    Survival = surv_std_obj$surv, 
    Model = "Standard Cox (No Reduction)",
    Patient = risk_group
  )
  
  # 3. PROPOSED MODEL CURVE
  Z_test_proj <- Z_test %*% fit_proposed$U
  df_test_proj <- as.data.frame(Z_test_proj)
  colnames(df_test_proj) <- names(coef(fit_proposed$final_model))
  patient_prop_data <- df_test_proj[patient_idx, , drop = FALSE]
  
  surv_prop_obj <- survfit(fit_proposed$final_model, newdata = patient_prop_data)
  df_prop <- tibble(
    Time = surv_prop_obj$time, 
    Survival = surv_prop_obj$surv, 
    Model = "Supervised PCA Cox (SVD)",
    Patient = risk_group
  )
  
  bind_rows(df_true, df_std, df_prop)
}

# Create data for all three patients
df_all <- bind_rows(
  create_survival_data(patient_indices[1], "Low Risk (25th percentile)"),
  create_survival_data(patient_indices[2], "Medium Risk (50th percentile)"),
  create_survival_data(patient_indices[3], "High Risk (75th percentile)")
)

